@{
    string brandName = ViewBag.BrandName;
    string websiteUrl = ViewBag.WebsiteUrl;
    string supportUrl = ViewBag.SupportUrl;
    string reason = ViewBag.FooterReason;
    string websiteLabel = websiteUrl.Replace("https://", "").Replace("http://", "").TrimEnd('/');
}
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td align="center" style="padding: 24px 24px 8px 24px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; line-height: 18px; color: #64748B;">
      <p style="margin: 0 0 12px 0;">@reason</p>
      <p style="margin: 0 0 12px 0;">
        <a href="@supportUrl" style="color: #475569; text-decoration: underline;">Contact support</a>
        &nbsp;&middot;&nbsp;
        <a href="@websiteUrl" style="color: #475569; text-decoration: underline;">@websiteLabel</a>
      </p>
      <p style="margin: 0;">&copy; @DateTime.UtcNow.Year @brandName. All rights reserved.</p>
    </td>
  </tr>
</table>
