@using OpenCaptive.Infrastructure.Email.Components
@model AlertModel
@{
    string accent;
    string background;
    string titleColor;
    string icon;

    switch (Model.Variant)
    {
        case AlertVariant.Success:
            accent = "#16A34A";
            background = "#F0FDF4";
            titleColor = "#166534";
            icon = "✓";
            break;
        case AlertVariant.Warning:
            accent = "#D97706";
            background = "#FFFBEB";
            titleColor = "#92400E";
            icon = "!";
            break;
        case AlertVariant.Error:
            accent = "#DC2626";
            background = "#FEF2F2";
            titleColor = "#991B1B";
            icon = "✕";
            break;
        default:
            accent = "#2563EB";
            background = "#EFF6FF";
            titleColor = "#1E3A8A";
            icon = "i";
            break;
    }
}
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 0 0 24px 0; background-color: @background; border: 1px solid #E2E8F0; border-left: 4px solid @accent; border-radius: 8px;">
  <tr>
    <td style="padding: 16px;">
      <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td width="28" valign="top" style="width: 28px; vertical-align: top;">
            <div style="width: 20px; height: 20px; background-color: @accent; border-radius: 10px; color: #FFFFFF; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; font-weight: 700; line-height: 20px; text-align: center;">@icon</div>
          </td>
          <td valign="top" style="vertical-align: top; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
            <div style="font-size: 14px; line-height: 22px; font-weight: 600; color: @titleColor;">@Model.Title</div>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
              <div style="margin-top: 4px; font-size: 14px; line-height: 22px; color: #475569;">@Model.Description</div>
            }
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
