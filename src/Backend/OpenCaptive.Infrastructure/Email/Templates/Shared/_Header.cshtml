@{
    string brandName = ViewBag.BrandName;
}
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td align="center" style="padding: 8px 0 24px 0;">
      <table role="presentation" border="0" cellpadding="0" cellspacing="0">
        <tr>
          <td style="vertical-align: middle; padding-right: 10px;">
            <div style="width: 36px; height: 36px; background-color: #4F46E5; border-radius: 8px; color: #FFFFFF; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 20px; font-weight: 700; line-height: 36px; text-align: center;">
              O
            </div>
          </td>
          <td style="vertical-align: middle;">
            <span style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 20px; font-weight: 700; line-height: 36px; color: #0F172A;">@brandName</span>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
