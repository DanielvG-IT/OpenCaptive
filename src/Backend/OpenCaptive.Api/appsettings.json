{
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { 
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Frontend": {
    "BaseUrl": "https://app.opencaptive.com",
    "VerifyEmailPath": "/verify-email",
    "ResetPasswordPath": "/reset-password"
  },
  "Email": {
    "Timeout": "00:00:10",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "Username": "",
      "Password": "",
      "EnableSsl": true
    },
    "FromAddress": "",
    "FromName": ""
  },
  "Authentication": {
    "Jwt": {
      "SigningKey": "...",
      "Issuer": "...",
      "Audience": "...",
      "Lifetime": "00:15:00",
      "ClockSkew": "00:00:00"
    },
    "RefreshToken": {
      "Lifetime": "30.00:00:00"
    },
    "EmailVerification": {
      "TokenLifetime": "2.00:00:00"
    },
    "PasswordReset": {
      "TokenLifetime": "2.00:00:00"
    },
    "TwoFactorAuthentication": {
      "AuthenticatorIssuer": "OpenCaptive"
    }
  }
}
