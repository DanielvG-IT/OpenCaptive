{
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { 
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Authentication": {
    "Jwt": {
      "SigningKey": "...",
      "Issuer": "...",
      "Audience": "...",
      "Lifetime": "00:15:00",
      "ClockSkew": "00:00:00"
    },
    "RefreshToken": {
      "Lifetime": "30.00:00:00"
    }
  }
}
